# MYAPP example configuration
#
# Copy to ~/.config/myapp/config.toml, or pass --config / MYAPP_CONFIG.
# Precedence: CLI flag > MYAPP_* env > MYAPP_*_FILE env > this file > defaults.

# Upstream API base URL. Env: MYAPP_BASE_URL
base_url = "http://localhost:8080"

# API key sent as the X-Api-Key header. Env: MYAPP_API_KEY
# api_key = "your-api-key"

# Secret-file alternative (Docker secret convention; trimmed on read).
# Mutually exclusive with api_key. Env: MYAPP_API_KEY_FILE
# api_key_file = "/run/secrets/myapp-api-key"

[log]
# trace|debug|info|warn|error. Env: MYAPP_LOG_LEVEL
level = "info"

[http]
# Env: MYAPP_HTTP_REQUEST_TIMEOUT_SECS / MYAPP_HTTP_CONNECT_TIMEOUT_SECS
request_timeout_secs = 30
connect_timeout_secs = 10

[mcp]
# HTTP transport bind. Env: MYAPP_MCP_HOST / MYAPP_MCP_PORT
# host = "127.0.0.1"
# port = 8080

# Auth mode for the MCP endpoint: "token" | "oauth" | "none".
# Env: MYAPP_MCP_AUTH_MODE
# auth_mode = "token"

# Static bearer token for auth_mode="token". Env: MYAPP_MCP_TOKEN / _FILE
# token = ""
# token_file = "/run/secrets/myapp-mcp-token"

# External base URL for OAuth metadata. Env: MYAPP_MCP_BASE_URL
# base_url = "https://mcp.example.com"

# OAuth consent PIN. Env: MYAPP_MCP_OAUTH_PIN / _FILE
# oauth_pin = ""
# oauth_pin_file = "/run/secrets/myapp-mcp-oauth-pin"

# Cap on serialized tool-result size (bytes); oversized results are replaced
# with a bounded `response_too_large` error. Env: MYAPP_MCP_MAX_RESPONSE_BYTES
# max_response_bytes = 1048576  # default: 1 MiB
